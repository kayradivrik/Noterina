{
  "name": "notes-desktop",
  "version": "1.0.0",
  "description": "Notion-style desktop note-taking app. Electron + React + TypeScript. Offline-first, local storage.",
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/YOUR_USERNAME/notes-desktop.git"
  },
  "keywords": [
    "notes",
    "electron",
    "react",
    "tiptap",
    "desktop",
    "notion",
    "markdown",
    "offline"
  ],
  "main": "dist-electron/main/main.js",
  "scripts": {
    "build:electron": "tsc -p tsconfig.electron.json",
    "dev": "npm run build:electron && concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "npm run build:electron && vite build && electron-builder",
    "preview": "vite preview",
    "vite": "vite",
    "electron": "electron ."
  },
  "dependencies": {
    "@tiptap/core": "^2.10.3",
    "@tiptap/extension-blockquote": "^2.10.3",
    "@tiptap/extension-bullet-list": "^2.10.3",
    "@tiptap/extension-code-block": "^2.10.3",
    "@tiptap/extension-document": "^2.10.3",
    "@tiptap/extension-heading": "^2.10.3",
    "@tiptap/extension-history": "^2.27.2",
    "@tiptap/extension-horizontal-rule": "^2.10.3",
    "@tiptap/extension-image": "^2.27.2",
    "@tiptap/extension-list-item": "^2.10.3",
    "@tiptap/extension-ordered-list": "^2.10.3",
    "@tiptap/extension-paragraph": "^2.10.3",
    "@tiptap/extension-placeholder": "^2.10.3",
    "@tiptap/extension-task-item": "^2.10.3",
    "@tiptap/extension-task-list": "^2.10.3",
    "@tiptap/extension-text": "^2.10.3",
    "@tiptap/react": "^2.10.3",
    "@tiptap/starter-kit": "^2.10.3",
    "lucide-react": "^0.460.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.0.1",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.notes.app",
    "productName": "Notes",
    "icon": "public/sas.png",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "public/sas.png"
    ]
  }
}
